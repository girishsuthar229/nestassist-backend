# -----------------------------
# Server
# -----------------------------
PORT=5000
NODE_ENV=development       # development / production


# -----------------------------
# PostgreSQL / Sequelize
# -----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_LOGGING=false            # true/false to enable Sequelize query logging


# -----------------------------
# Cloudinary
# -----------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=home_mang  # main folder for uploads

# -----------------------------
# File Upload Config
# -----------------------------
MAX_FILE_SIZE_MB=2           # Maximum upload size in MB
ALLOWED_FILE_TYPES=image/png,image/jpeg,image/jpg

# -----------------------------
# SMTP / Email
# -----------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_mail
MAIL_PASSWORD=your_pass
MAIL_FROM_ADDRESS=your_mail
MAIL_FROM_NAME="NestAssist"

STRIPE_SECRET_KEY=STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET 
ENABLE_BOOKING_CRON=false

RAZORPAY_KEY_ID=razorpay_key_id
RAZORPAY_SECRET_KEY=razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret

REDIS_URL=redis_cloud_url
REDIS_PORT=redis_port
REDIS_USERNAME=redis_username
REDIS_PASSWORD=redis_password

FRONTEND_URL=FRONTEND_URL

JWT_SECRET=JWT_SECRET

RATE_LIMIT_GET_WINDOW_MS=RATE_LIMIT_GET_WINDOW_SECONDS
RATE_LIMIT_GET_MAX=RATE_LIMIT_GET_MAX
JWT_EXPIRES_IN=JWT_EXPIRES_IN             # Token lifetime in seconds (default: 8 hours)
JWT_EXPIRY=JWT_EXPIRY

RATE_LIMIT_BOOKING_UPDATE_WINDOW_MS=60000
RATE_LIMIT_BOOKING_UPDATE_MAX=60

RATE_LIMIT_BOOKING_DELETE_WINDOW_MS=60000
RATE_LIMIT_BOOKING_DELETE_MAX=30

RATE_LIMIT_SERVICE_POST_WINDOW_MS=60000
RATE_LIMIT_SERVICE_POST_MAX=20

RATE_LIMIT_SERVICE_PUT_WINDOW_MS=60000
RATE_LIMIT_SERVICE_PUT_MAX=30

RATE_LIMIT_SERVICE_PATCH_WINDOW_MS=60000
RATE_LIMIT_SERVICE_PATCH_MAX=60

RATE_LIMIT_SERVICE_DELETE_WINDOW_MS=60000
RATE_LIMIT_SERVICE_DELETE_MAX=40

APP_URL=APP_URL